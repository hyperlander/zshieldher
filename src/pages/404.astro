---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" showBanner={false}>
  <div class="min-h-[70vh] flex items-center justify-center text-center px-6 py-20">
    <div class="max-w-md">
      <p class="text-5xl mb-6" aria-hidden="true">🛡</p>
      <h1>Page not found</h1>
      <p class="text-gray-500 mt-4 mb-10 leading-relaxed">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/" class="btn btn-primary">Go home →</a>
        <a href="/learn/" class="btn btn-secondary">Start learning →</a>
      </div>
    </div>
  </div>
</BaseLayout>
