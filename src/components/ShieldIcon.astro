---
interface Props {
  size?: number;
}
const { size = 22 } = Astro.props;
---
<!--
  Shield icon — matches the favicon exactly:
  sand-filled shield with a dark-green Z mark inside.
  Works on the dark-green header/footer background.
-->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 20 24"
  width={size}
  height={size}
  fill="none"
  aria-hidden="true"
  style="flex-shrink:0"
>
  <!-- Shield body -->
  <path
    d="M10 1 C4 1 1 4 1 7 L1 15 C1 21 10 23 10 23 C10 23 19 21 19 15 L19 7 C19 4 16 1 10 1 Z"
    fill="#f5f0e8"
  />
  <!-- Z mark (Zcash link) -->
  <path
    d="M6 8 L14 8 L6 16 L14 16"
    stroke="#1a4a3a"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
