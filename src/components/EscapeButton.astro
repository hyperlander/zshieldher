---
// Single-click escape — replaces history entry and navigates to neutral site.
// Alt+X keyboard shortcut registered in BaseLayout script.
---
<button
  id="escape-btn"
  class="escape-btn"
  title="Leave this page immediately (Alt+X)"
  aria-label="Leave this page immediately"
>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path d="M18 6L6 18M6 6l12 12"/>
  </svg>
  Leave this page
</button>
